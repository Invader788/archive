
# --- Window ---
[window]
padding = { x = 10, y = 10 }
dynamic_padding = true
opacity = 0.45
decorations = "None"

# --- Colors ---
[colors.primary]
background = "#FFFFFF"
foreground = "#000000"

# --- Font ---
[font]
size = 9

[font.normal]
family = "MartianMono Nerd Font"
style = "Regular"

[font.bold]
family = "MartianMono Nerd Font"
style = "Bold"

[font.italic]
family = "MartianMono Nerd Font"
style = "Italic"

# --- Colors (Nord) ---
[colors.primary]
background = "#2E3440"
foreground = "#D8DEE9"

[colors.normal]
black   = "#3B4252"
red     = "#BF616A"
green   = "#A3BE8C"
yellow  = "#EBCB8B"
blue    = "#81A1C1"
magenta = "#B48EAD"
cyan    = "#88C0D0"
white   = "#E5E9F0"

[colors.bright]
black   = "#4C566A"
red     = "#BF616A"
green   = "#A3BE8C"
yellow  = "#EBCB8B"
blue    = "#81A1C1"
magenta = "#B48EAD"
cyan    = "#8FBCBB"
white   = "#ECEFF4"

# --- Cursor ---
[cursor]
style = { shape = "Beam", blinking = "On" }

# --- Shell ---
[terminal.shell]
program = "/usr/bin/zsh"

# --- Keybindings ---
[[keyboard.bindings]]
key = "Z"
mods = "Control|Shift"
action = "DecreaseFontSize"

[[keyboard.bindings]]
key = "X"
mods = "Control|Shift"
action = "IncreaseFontSize"

# --- Window ---
[window]
padding = { x = 10, y = 10 }
dynamic_padding = true
opacity = 0.58
decorations = "None"

# --- Font ---
[font]
size = 9

[font.normal]
family = "MartianMono Nerd Font"
style = "Regular"

[font.bold]
family = "MartianMono Nerd Font"
style = "Bold"

[font.italic]
family = "MartianMono Nerd Font"
style = "Italic"

# --- Colors (Soft Catppuccin-inspired theme) ---
[colors.primary]
background = "#1e1e2e"  # soft deep charcoal purple
foreground = "#d9e0ee"  # slightly warm white

[colors.normal]
black   = "#313244"
red     = "#eba0ac"
green   = "#a6e3a1"
yellow  = "#f9e2af"
blue    = "#89b4fa"
magenta = "#cba6f7"
cyan    = "#94e2d5"
white   = "#cdd6f4"

[colors.bright]
black   = "#45475a"
red     = "#f2b8c6"
green   = "#b6f2b6"
yellow  = "#fbe7b0"
blue    = "#a6c8ff"
magenta = "#d7bdf7"
cyan    = "#a8e8e0"
white   = "#e6e9ef"

# --- Cursor ---
[cursor]
style = { shape = "Beam", blinking = "On" }

# --- Shell ---
[terminal.shell]
program = "/usr/bin/zsh"

# --- Keybindings ---
[[keyboard.bindings]]
key = "Z"
mods = "Control|Shift"
action = "DecreaseFontSize"

[[keyboard.bindings]]
key = "X"
mods = "Control|Shift"
action = "IncreaseFontSize"

# --- Window ---
window:
  padding:
    x: 12
    y: 12
  dynamic_padding: true
  opacity: 0.85
  decorations: none

# --- Font ---
font:
  normal:
    family: "MartianMono Nerd Font"
    style: Regular
  bold:
    family: "MartianMono Nerd Font"
    style: Bold
  italic:
    family: "MartianMono Nerd Font"
    style: Italic
  size: 20

# --- Colors (modern dark) ---
colors:
  primary:
    background: "#0d0f18"
    foreground: "#cdd6f4"

  normal:
    black:   "#1e1e2e"
    red:     "#f38ba8"
    green:   "#a6e3a1"
    yellow:  "#f9e2af"
    blue:    "#89b4fa"
    magenta: "#cba6f7"
    cyan:    "#94e2d5"
    white:   "#bac2de"

  bright:
    black:   "#585b70"
    red:     "#f38ba8"
    green:   "#a6e3a1"
    yellow:  "#f9e2af"
    blue:    "#89b4fa"
    magenta: "#cba6f7"
    cyan:    "#94e2d5"
    white:   "#a6adc8"

# --- Cursor ---
cursor:
  style:
    shape: Beam
    blinking: On

# --- Shell (Zsh) ---
shell:
  program: /usr/bin/zsh

# --- Silence warnings ---
env:
  RUST_LOG: error

live_config_reload: false

# --- Keybindings ---
key_bindings:
  - { key: Z, mods: Control|Shift, action: DecreaseFontSize }
  - { key: X, mods: Control|Shift, action: IncreaseFontSize }